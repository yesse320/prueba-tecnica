# ─────────────────────────────────────────────────────────────
# Variables de entorno — Help Desk EduLabs
# Copia este archivo como ".env.local" y completa los valores.
# NO subas .env.local al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Supabase — Dashboard > Project Settings > Data API / API Keys
# El URL tiene la forma https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica

# OpenRouter — crea una key gratis en https://openrouter.ai/keys
# Si se deja vacía, el asistente de IA funciona en modo "simulado".
OPENROUTER_API_KEY=tu_openrouter_api_key
